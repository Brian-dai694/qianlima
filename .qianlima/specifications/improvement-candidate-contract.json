{
  "schema_version": 1,
  "contract_id": "qianlima-improvement-candidate-contract",
  "contract_version": "1.0.0",
  "purpose": "Keep harness and governance improvements isolated until independent evaluation and explicit human promotion.",
  "lifecycle_states": ["draft", "specified", "planned", "analyzed", "shadow_converged", "promotion_candidate", "frozen", "rejected"],
  "required_fields": [
    "candidate_id",
    "candidate_version",
    "lifecycle_state",
    "north_star_protocol_version",
    "target_layer",
    "target_files",
    "hypothesis",
    "expected_benefit",
    "proposed_by_agent_id",
    "tested_with",
    "baseline_version",
    "evaluation",
    "independent_verifier",
    "permission_impact",
    "rollback_plan",
    "human_approval",
    "proposed_change",
    "privacy"
  ],
  "allowed_target_layers": ["entry_rule", "task_card", "workflow", "skill", "router", "middleware", "runtime", "specification"],
  "required_evaluations": ["update_validation", "id_holdout", "ood_holdout", "replay", "latency_regression", "L4_safety"],
  "allowed_evidence_classifications": ["public", "internal_sanitized"],
  "approved_evidence_root": ".qianlima/evolution/eval-cases/",
  "approved_target_patterns": [
    ".qianlima/enterprise-governance-framework.json",
    ".qianlima/enterprise-governance-control-matrix.md",
    ".qianlima/credential-policy.json",
    ".qianlima/execution-runner-schema.yaml",
    ".qianlima/execution-runners.json",
    ".qianlima/specifications/*",
    ".qianlima/scripts/validate-*.ps1",
    ".qianlima/scripts/invoke-*.ps1",
    ".qianlima/scripts/check-*.ps1",
    ".qianlima/scripts/scan-*.ps1",
    ".qianlima/scripts/record-*.ps1"
  ],
  "prohibited_field_names": ["raw_prompt", "hidden_reasoning", "secret_value", "raw_private_data", "full_tool_parameters", "credential_value", "api_key", "access_token", "customer_identifier", "browser_export"],
  "invariants": [
    "A candidate is evidence for a possible change, not a production authority.",
    "Candidate evaluation must use sanitized evidence and an independent verifier.",
    "A producer, tested Agent, or proposing Agent cannot verify its own candidate.",
    "Permission or attack-surface expansion requires explicit human approval and never auto-enables the capability.",
    "Replay, holdout, latency, and L4 safety failures freeze the candidate.",
    "Promotion produces a promotion candidate record; it never edits production files automatically.",
    "A rollback reference and trigger are mandatory before a candidate can converge."
  ]
}
