{
  "schema_version": 1,
  "contract_type": "qianlima_personal_ad_ops_loop",
  "contract_version": "1.0.0",
  "edition": "personal",
  "purpose": "Run a local, read-only ad-operations loop from anomaly discovery to evidence-backed action candidates and optional result readback.",
  "stages": ["read", "validate", "diagnose", "recommend", "verify", "handoff", "readback", "review"],
  "input": {
    "format": "csv",
    "required_fields": ["date", "marketplace", "campaign_name", "ad_group_name", "search_term", "impressions", "clicks", "spend", "sales", "orders", "budget"],
    "optional_fields": ["current_bid"],
    "source_mode": "local_reference_only",
    "readback_is_optional": true
  },
  "metrics": {
    "required": ["spend", "sales", "orders", "acos", "cpc", "ctr", "cvr"],
    "empty_denominator": "return_null_and_mark_pending"
  },
  "diagnostics": [
    {"id": "high_spend_no_order", "condition": "spend >= 10 and orders = 0", "candidate": "decrease_bid"},
    {"id": "high_acos", "condition": "acos > target_acos * 1.3 and orders >= 1", "candidate": "decrease_bid"},
    {"id": "high_click_low_conversion", "condition": "clicks >= 15 and orders = 0", "candidate": "pause"},
    {"id": "strong_performance", "condition": "acos <= target_acos and orders >= 2", "candidate": "keep"}
  ],
  "action_candidates": {
    "allowed": ["pause", "decrease_bid", "increase_bid", "adjust_budget", "keep"],
    "requires_confirmation": ["pause", "decrease_bid", "increase_bid", "adjust_budget"],
    "never_execute": ["change_bid", "change_budget", "pause_campaign", "publish_listing", "send_external", "delete", "overwrite_source"],
    "control_plane_handoff": "required_for_any_business_write"
  },
  "verification": {
    "required": ["input_hash", "rows_read", "source_date", "data_quality", "artifact_hash", "pending_verification", "evidence_receipt"],
    "readback": "compare_optional_post_action_export_against_baseline",
    "adoption_rule": "missing_or_conflicting_evidence_blocks_adoption"
  },
  "action_card": "specifications/personal-ad-action-card-contract.json",
  "completion_definition": ["goal_clear", "source_bound", "action_card_created", "evidence_created", "readback_or_pending_state", "review_next_step"],
  "side_effects": {"external_calls": false, "business_writes": false, "permissions_granted": false, "delegation": false}
}
