{
  "schema_version": 1,
  "policy_id": "qianlima-credential-reference-policy",
  "default_action": "deny",
  "storage": "secret_manager_or_runner_process_environment",
  "secret_values_in_qianlima": "prohibited",
  "prohibited_locations": ["prompt", "command_args", "work_order", "delegation_grant", "artifact_receipt", "audit_event", "Git", "host_workspace"],
  "runtime_rules": {
    "inject_only_inside_runner": true,
    "pass_by_reference_only": true,
    "child_delegation": false,
    "file_export": false,
    "log_values": false,
    "task_end_revoke": true,
    "max_task_ttl_minutes": 30,
    "rotation_owner": "human_owner_or_secret_manager"
  },
  "references": [
    {
      "credential_id": "model_provider_openai",
      "provider": "openai",
      "environment_variable": "QIANLIMA_OPENAI_API_KEY",
      "allowed_consumers": ["docker_local_isolated", "codex_supervisor"],
      "scope": "model_inference_only",
      "network_allowlist": ["api.openai.com"],
      "enabled": false
    },
    {
      "credential_id": "model_provider_anthropic",
      "provider": "anthropic",
      "environment_variable": "QIANLIMA_ANTHROPIC_API_KEY",
      "allowed_consumers": ["docker_local_isolated", "claude_code_worker"],
      "scope": "model_inference_only",
      "network_allowlist": ["api.anthropic.com"],
      "enabled": false
    },
    {
      "credential_id": "mcp_readonly_gateway",
      "provider": "qianlima_mcp_gateway",
      "environment_variable": "QIANLIMA_MCP_GATEWAY_TOKEN",
      "allowed_consumers": ["docker_local_isolated"],
      "scope": "allowlisted_readonly_mcp_only",
      "network_allowlist": [],
      "enabled": false
    }
  ]
}
