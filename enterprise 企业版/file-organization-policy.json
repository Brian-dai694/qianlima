{
  "schema_version": 1,
  "policy_id": "qianlima-enterprise-file-organization",
  "root": ".qianlima/local-data/enterprise/artifacts",
  "path_template": "{business}/{department}/{risk_level}/{year_month}/{task_id}/{artifact_type}/{file_name}",
  "required_dimensions": ["business", "department", "risk_level", "year_month", "task_id", "artifact_type"],
  "risk_levels": ["L0", "L1", "L2", "L3", "L4"],
  "artifact_types": ["input_reference", "working", "outcome", "evidence", "verification", "failure", "core_issue", "handling", "review", "lesson_candidate", "audit_receipt"],
  "required_metadata": ["organization_id", "business", "department", "risk_level", "task_id", "trace_id", "owner_id", "data_classification", "artifact_type", "created_at", "retention_policy", "integrity_hash", "verification_status"],
  "access": {
    "employee": "own_department_and_assigned_projects",
    "department_manager": "assigned_department",
    "business_owner": "summary_and_approved_artifacts",
    "security_admin": "security_metadata_not_raw_business_content",
    "cross_department": "explicit_L3_or_L4_grant"
  },
  "rules": [
    "New artifacts use the generated path; users do not invent alternate enterprise roots.",
    "L4 artifacts are never placed in public or personal sync folders.",
    "Artifact payload and audit receipt remain separate.",
    "Terminal artifacts are immutable; revisions create a new task or version reference.",
    "Existing files are not moved automatically; migration creates a reviewed candidate plan.",
    "Secrets and credential values are prohibited at every level."
  ]
}
