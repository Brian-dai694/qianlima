{
  "schema_version": 1,
  "connector_id": "qianlima-obsidian-knowledge-connector",
  "status": "interface_reserved_not_connected",
  "positioning": "Obsidian is a governed knowledge data plane, never a policy or memory authority.",
  "transport_options": ["local_filesystem_adapter", "approved_mcp"],
  "default_action": "deny",
  "default_mode": "allowlist_read_only",
  "vault_path_mode": "reference_only",
  "direct_agent_access": "deny",
  "broker_required": true,
  "read_operations": ["search_notes", "read_selected_note", "read_frontmatter", "list_backlinks", "list_selected_folder"],
  "draft_operation": "prepare_note_draft_without_vault_write",
  "write_operations_reserved": ["create_note", "update_note", "move_note"],
  "always_denied_operations": ["delete_note", "delete_attachment", "install_plugin", "enable_plugin", "execute_command", "execute_javascript", "open_external_url", "export_entire_vault"],
  "allowed_file_types_default": [".md"],
  "attachment_access": "deny_unless_separately_allowlisted_by_media_type_and_task",
  "required_scope": ["organization_id", "employee_id", "task_id", "agent_id", "grant_id", "vault_ref", "allowed_folder_refs", "allowed_note_refs", "data_classification", "budget", "expires_at"],
  "read_requirements": ["enabled_connector", "active_task_grant", "verified_attestation", "selected_vault_ref", "allowlisted_folder_or_note", "allowed_file_type", "freshness_metadata", "content_hash", "audit_event"],
  "write_requirements": ["dedicated_write_adapter", "Enterprise_L4", "responsible_approval_profile", "exact_target_note_ref", "idempotency_key", "preflight_snapshot", "write_receipt", "post_write_hash", "grant_revocation_after_task"],
  "result_metadata": ["vault_ref", "note_ref", "relative_path", "modified_at", "content_sha256", "frontmatter_schema_version", "classification", "fetched_at"],
  "privacy": {
    "full_vault_index": "deny",
    "hidden_folders": [".obsidian", ".git", ".trash"],
    "secrets_and_tokens": "deny",
    "raw_private_content_externalization": "deny",
    "minimum_selected_content_only": true
  },
  "failure": {
    "vault_path_changed": "freeze_and_reapprove_reference",
    "note_hash_changed": "mark_stale_and_reread_before_decision",
    "scope_escape": "revoke_and_record_incident",
    "plugin_or_command_requested": "deny_and_record_attempt",
    "write_receipt_missing": "unconfirmed_not_completed"
  }
}
