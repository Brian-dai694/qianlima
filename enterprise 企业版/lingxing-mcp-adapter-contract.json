{
  "schema_version": 1,
  "adapter_id": "qianlima-lingxing-mcp",
  "status": "interface_reserved_not_connected",
  "transport": "MCP",
  "default_mode": "allowlist_read_only",
  "direct_agent_access": "deny",
  "broker_required": true,
  "credential_mode": "secret_ref_only",
  "required_context": ["tenant_id", "organization_id", "employee_id", "task_id", "grant_id", "shop_scope", "marketplace_scope", "data_classification", "cost_center"],
  "read_capabilities": {
    "initialization": ["get_shop_authorization_status", "get_product_configuration", "get_warehouse_configuration", "get_logistics_configuration"],
    "operations": ["get_listings", "get_orders", "get_sales_analysis", "get_product_performance", "get_promotions", "get_customer_service_status", "get_alerts"],
    "advertising": ["get_advertising_summary", "get_campaigns", "get_search_terms", "get_keyword_rank", "get_budget_analysis", "get_daypart_analysis"],
    "finance": ["get_settlement_transactions", "get_profit_report", "get_cost_detail", "get_receivables", "get_shipping_settlement_difference"],
    "supply_chain": ["get_purchase_plans", "get_purchase_orders", "get_shipments", "get_fba_shipments", "get_first_mile_reconciliation", "get_inventory", "get_replenishment_advice", "get_stocktake_status"]
  },
  "write_capabilities_reserved": ["update_listing", "update_advertising", "update_promotion", "send_customer_message", "request_review", "create_purchase_order", "change_purchase_order", "create_shipment", "adjust_inventory", "submit_stocktake"],
  "read_requirements": ["allowlisted_server", "active_grant", "verified_attestation", "shop_scope", "selected_fields", "pagination_budget", "freshness_timestamp", "audit_event"],
  "write_requirements": ["dedicated_write_adapter", "Enterprise_L4", "responsible_approval_profile", "idempotency_key", "preflight_snapshot", "rollback_or_compensation", "Lingxing_receipt", "post_change_verification"],
  "normalization": {
    "required_metadata": ["lingxing_account_ref", "shop_ref", "marketplace", "source_record_id", "source_updated_at", "fetched_at", "request_id", "page_cursor", "data_classification"],
    "money": "amount_plus_currency",
    "time": "UTC_timestamp_plus_marketplace_timezone",
    "sku_identity": "seller_sku_plus_asin_plus_fnsku_when_available",
    "missing_value": "unknown_not_zero"
  },
  "failure": {
    "authorization_expired": "freeze_and_request_reauthorization",
    "rate_limited": "bounded_retry_then_partial",
    "schema_drift": "isolate_adapter_version",
    "stale_data": "mark_pending_verification",
    "write_receipt_missing": "unconfirmed_not_completed"
  }
}
