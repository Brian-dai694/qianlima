{
  "schema_version": 1,
  "policy_id": "qianlima-enterprise-employee-lifecycle",
  "source_of_truth": "approved_HR_or_enterprise_identity_directory",
  "physical_employee_delete": "deny",
  "states": ["invited", "active", "suspended", "transferred", "offboarded"],
  "actions": {
    "join": {
      "target_state": "invited",
      "required_approvals": ["department_manager"],
      "default_role": "employee",
      "default_scope": "own_department_and_assigned_projects",
      "default_agent_trust": "T0",
      "default_mcp_access": "none"
    },
    "activate": {
      "target_state": "active",
      "required_checks": ["enterprise_identity_created", "department_assigned", "manager_assigned", "device_enrollment_started"],
      "execution_authority": "none_until_device_agent_and_task_grants_pass"
    },
    "transfer": {
      "target_state": "transferred",
      "required_approvals": ["current_department_manager", "new_department_manager"],
      "order": ["freeze_new_work", "revoke_old_department_grants", "revoke_direct_mcp_sessions", "handover_tasks", "change_department", "recalculate_scope", "issue_new_grants_only_after_new_manager_approval"]
    },
    "suspend": {
      "target_state": "suspended",
      "required_approval_any": ["department_manager", "HR", "security_admin"],
      "actions": ["disable_new_login", "freeze_new_work", "revoke_active_grants", "revoke_direct_mcp_sessions", "preserve_artifacts_and_audit"]
    },
    "offboard": {
      "target_state": "offboarded",
      "required_approvals": ["HR", "department_manager"],
      "required_handover_owner": true,
      "actions": ["disable_identity", "terminate_agent_sessions", "revoke_all_grants", "revoke_direct_mcp_sessions", "revoke_credential_assignments", "isolate_or_recover_devices", "transfer_open_tasks", "transfer_artifact_ownership", "stop_employee_cost_attribution", "preserve_immutable_history"]
    },
    "emergency_offboard": {
      "target_state": "offboarded",
      "required_approvals": ["security_admin"],
      "immediate_actions": ["disable_identity", "terminate_agent_sessions", "revoke_all_grants", "revoke_direct_mcp_sessions", "isolate_devices"],
      "follow_up": ["HR_review", "manager_handover", "incident_record", "artifact_ownership_transfer"]
    }
  },
  "contractor": {
    "expires_at_required": true,
    "expiry_action": "automatic_suspend_and_revoke",
    "renewal_requires_manager_approval": true
  },
  "sync_interfaces": {
    "preferred": ["SCIM", "enterprise_identity_directory", "HR_webhook"],
    "supported_adapters": ["Microsoft_Entra_ID", "Feishu", "WeCom", "generic_SCIM", "CSV_import"],
    "incoming_event_authority": "identity_state_signal_only",
    "qianlima_authority": "Agent_device_task_data_MCP_and_grant_revocation"
  },
  "invariants": [
    "A role change never expands permissions before old grants are revoked.",
    "An offboarded employee cannot own an active Grant or direct MCP session.",
    "Historical approvals and receipts remain attributable to the identity valid at that time.",
    "Employee status changes create append-only events and never rewrite history."
  ]
}
