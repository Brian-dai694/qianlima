{
  "schema_version": 1,
  "platform_id": "qianlima-enterprise-mcp-governance",
  "principle": "MCP exposes tools and data; Qianlima decides whether a specific task may use them.",
  "default_action": "deny",
  "direct_agent_to_mcp": "allow_only_with_broker_signed_direct_session",
  "broker_required": "for_admission_and_session_grant_issuance",
  "personal_mcp_authority_in_enterprise": "deny",
  "server_categories": [
    "file_and_cloud_storage",
    "commerce_erp",
    "finance_tax_customs",
    "database_and_bi",
    "advertising_and_marketing",
    "logistics_and_inventory",
    "supplier_and_procurement",
    "collaboration_and_messaging",
    "search_and_research",
    "code_and_devops",
    "identity_and_organization",
    "security_and_compliance"
  ],
  "required_server_passport": [
    "server_id",
    "owner_id",
    "vendor",
    "version",
    "category",
    "transport",
    "endpoint_ref",
    "credential_ref",
    "network_zone",
    "data_classifications",
    "tool_manifest_hash",
    "allowed_tools",
    "operation_classes",
    "rate_limit",
    "timeout_ms",
    "cost_model",
    "health_status",
    "last_contract_test_at",
    "trust_level"
  ],
  "operation_classes": {
    "discover": {"minimum_level": "L1", "write": false},
    "read_selected": {"minimum_level": "L2", "write": false},
    "analyze": {"minimum_level": "L2", "write": false},
    "cross_source_analyze": {"minimum_level": "L3", "write": false},
    "prepare_draft": {"minimum_level": "L3", "write": false},
    "create": {"minimum_level": "L4", "write": true},
    "update": {"minimum_level": "L4", "write": true},
    "send": {"minimum_level": "L4", "write": true},
    "submit": {"minimum_level": "L4", "write": true},
    "delete": {"minimum_level": "L4", "write": true}
  },
  "read_requirements": ["enabled_server", "matching_server_version", "allowlisted_tool", "active_task_grant", "verified_attestation", "selected_data_scope", "budget", "freshness_metadata", "audit_event"],
  "write_requirements": ["dedicated_write_adapter", "Enterprise_L4", "responsible_approval_profile", "idempotency_key", "preflight_snapshot_or_compensation", "write_receipt", "post_change_verification", "grant_revocation_after_task"],
  "direct_session": {
    "business_owner_approval_required": true,
    "connector_enforcement_required": true,
    "central_broker_in_data_path": false,
    "bound_fields": ["session_grant_id", "organization_id", "employee_id", "task_id", "agent_id", "agent_version", "device_id", "server_id", "server_version", "tool_manifest_hash", "allowed_tools", "data_scope", "budget", "expires_at"],
    "may_delegate": false,
    "may_expand_scope": false,
    "revocation_check": "before_every_tool_call",
    "write_authority_inherited": false
  },
  "data_rules": {
    "public": "allow_if_task_selected",
    "internal_sanitized": "allow_if_task_and_server_scope_match",
    "confidential_reference_only": "reference_and_minimum_fields_only",
    "restricted_secret": "deny_payload_use_secret_reference_only",
    "external_server_allowed": ["public", "internal_sanitized"]
  },
  "cost_and_budget": {
    "required_receipt_fields": ["server_id", "tool_id", "task_id", "request_count", "provider_units", "provider_cost", "currency", "cost_status", "rate_card_version"],
    "unknown_cost": "record_unknown_not_estimated_exactly",
    "budget_exhausted": "revoke_and_freeze"
  },
  "drift_and_failure": {
    "server_version_change": "trust_reset_and_contract_retest",
    "tool_manifest_change": "freeze_new_calls_until_review",
    "schema_drift": "isolate_adapter_version",
    "three_failures": "circuit_break",
    "timeout": "bounded_retry_then_partial",
    "missing_receipt": "unconfirmed_not_completed",
    "overreach": "revoke_isolate_and_record_incident"
  },
  "adapter_examples": {
    "lingxing": "lingxing-mcp-adapter-contract.json",
    "obsidian": "obsidian-connector-contract.json",
    "tax_customs_compliance": "compliance-mcp-policy.json",
    "future": "register through mcp-server-registry.example.json and pass the generic gate"
  }
}
