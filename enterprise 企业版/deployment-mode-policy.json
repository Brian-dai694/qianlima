{
  "schema_version": 1,
  "policy_id": "qianlima-enterprise-api-agent-deployment-modes",
  "default_mode": "E2",
  "selection_questions": ["enterprise_pays_and_controls_api", "enterprise_requires_one_agent"],
  "modes": {
    "E1": {
      "enterprise_api": true,
      "enterprise_agent": true,
      "provider_account": "enterprise_managed",
      "agent_selection": "single_enterprise_agent",
      "credential_mode": "gateway_short_lived_secret_ref",
      "cost_owner": "enterprise",
      "initial_trust_ceiling": "T3"
    },
    "E2": {
      "enterprise_api": true,
      "enterprise_agent": false,
      "provider_account": "enterprise_managed",
      "agent_selection": "governed_allowlist",
      "credential_mode": "gateway_short_lived_secret_ref",
      "cost_owner": "enterprise",
      "initial_trust_ceiling": "T2"
    },
    "E3": {
      "enterprise_api": false,
      "enterprise_agent": true,
      "provider_account": "employee_or_department_byok",
      "agent_selection": "single_enterprise_agent",
      "credential_mode": "byok_secret_ref_only",
      "cost_owner": "employee_or_department",
      "initial_trust_ceiling": "T2"
    },
    "E4": {
      "enterprise_api": false,
      "enterprise_agent": false,
      "provider_account": "employee_or_department_byok",
      "agent_selection": "registered_and_governed",
      "credential_mode": "byok_secret_ref_only",
      "cost_owner": "employee_or_department",
      "initial_trust_ceiling": "T1"
    }
  },
  "invariants": [
    "API ownership never grants enterprise data access.",
    "Agent installation never grants MCP or business write access.",
    "Every Agent and version must be registered before enterprise use.",
    "Credential values are never stored in organization profiles or task records.",
    "MCP and internal data access remain task-scoped and independently approved.",
    "Business writes remain Enterprise L4 in every deployment mode.",
    "E4 starts at T1 and cannot receive internal data or MCP access before separate admission."
  ],
  "version_change": {
    "agent_version_changed": "revalidate_and_shrink_to_T1",
    "provider_changed": "revalidate_data_processing_and_credential_reference",
    "credential_owner_changed": "revoke_existing_bindings_before_regrant"
  }
}
