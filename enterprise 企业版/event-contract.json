{
  "schema_version": 1,
  "contract_id": "qianlima-enterprise-append-only-event-contract",
  "purpose": "Record the governed Agent behavior chain without rewriting prior events or storing secrets.",
  "storage": "append_only_trace_or_approved_central_sink",
  "required_fields": ["event_id", "event_type", "created_at", "tenant_id", "organization_id", "user_id", "agent_id", "agent_version", "task_id", "grant_id", "trace_id", "policy_version", "decision"],
  "lineage_fields": ["parent_event_id", "work_order_ref", "artifact_refs", "evidence_refs", "runner_attestation_ref"],
  "allowed_events": ["employee_invited", "employee_activated", "employee_suspended", "employee_transferred", "employee_offboarded", "employee_access_revoked", "task_handover_assigned", "task_created", "task_state_changed", "agent_selected", "grant_issued", "grant_checked", "grant_revoked", "memory_read_requested", "tool_requested", "tool_allowed", "tool_denied", "artifact_received", "artifact_rejected", "verification_completed", "budget_warning", "trust_shrunk", "agent_isolated", "task_frozen", "artifact_superseded", "task_terminal", "review_created", "lesson_candidate_created", "lesson_replay_completed", "lesson_promotion_decided"],
  "decision_values": ["allow", "deny", "shrink", "pause", "isolate", "revoke", "freeze", "accept", "reject"],
  "immutable_rules": [
    "A prior event cannot be updated or deleted by a later task.",
    "A correction creates a new event referencing the prior event.",
    "A terminal task cannot be reopened; a revision creates a new task.",
    "Credential values, raw prompts, hidden reasoning, and unrestricted private data are prohibited.",
    "A revoked Grant must produce a deny decision before the next governed action."
  ],
  "delivery": {
    "push": ["approval_required", "budget_warning", "verification_failed", "task_frozen", "task_terminal"],
    "pull": ["current_task_state", "grant_state", "artifact_state", "audit_timeline"],
    "event_stream_is_source_of_truth": true,
    "projection_is_source_of_truth": false
  },
  "backpressure": {
    "verification_queue_high": "pause_new_multi_agent_delegations",
    "audit_sink_unavailable": "retain_local_append_only_and_deny_high_risk_completion",
    "tenant_budget_exhausted": "freeze_tenant_new_work_without_cross_tenant_impact"
  },
  "operator_projections": ["current_task_state", "agent_version_behavior_summary", "grant_and_revocation_history", "tenant_budget_and_backpressure", "artifact_verification_lineage", "security_incident_timeline"]
}
